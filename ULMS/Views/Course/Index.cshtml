@model IEnumerable<ULMS.Models.Course>

<div class="container mt-4">
    @if (TempData["Message"] != null)
    {
        <div id="toastBox" class="custom-toast show">
            @TempData["Message"]
        </div>
    }

    <h2 class="text-primary">Courses</h2>

    <p>
        @Html.ActionLink("Create New Course", "Create", null, new { @class = "btn btn-success" })
    </p>

    <table class="table table-striped table-bordered table-hover">
        <thead>
            <tr class="info">
                <th>Course Name</th>
                <th>Description</th>
                <th>Max Students</th>
                <th>Action</th>
            </tr>
        </thead>

        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.CourseName</td>
                    <td>@item.Description</td>
                    <td>@item.MaxStudents</td>
                    <td>
                        <a href="/Enrollment/Enroll/@item.CourseId" class="btn btn-primary btn-sm">
                            Enroll
                        </a>
                    </td>
                </tr>
            }
        </tbody>
    </table>

</div>
<script>
    document.addEventListener("DOMContentLoaded", function () {
        var toast = document.getElementById("toastBox");

        if (toast) {
            // already visible via 'show' class

            setTimeout(function () {
                toast.classList.remove("show");
            }, 3000);
        }
    });
</script>
