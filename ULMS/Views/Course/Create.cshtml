@model ULMS.Models.Course

<div class="container mt-4">

    <h2 class="text-primary">Create Course</h2>

    @using (Html.BeginForm())
    {
        @Html.AntiForgeryToken()

        <div class="form-group">
            <label>Course Name</label>
            @Html.TextBoxFor(m => m.CourseName, new { @class = "form-control" })
        </div>

        <div class="form-group">
            <label>Description</label>
            @Html.TextBoxFor(m => m.Description, new { @class = "form-control" })
        </div>

        <div class="form-group">
            <label>Max Students</label>
            @Html.TextBoxFor(m => m.MaxStudents, new { @class = "form-control" })
        </div>

        <br />

        <button type="submit" class="btn btn-success">Save</button>
        <a href="/Course" class="btn btn-secondary">Back</a>
    }

</div>